{
	"name": "domzlab",
	"version": "1.0.0",
	"description": "A premium blog and creative laboratory built with Eleventy.",
	"type": "module",
	"scripts": {
		"build": "cross-env NODE_NO_WARNINGS=1 npx @11ty/eleventy",
		"build-nocolor": "cross-env NODE_DISABLE_COLORS=1 NODE_NO_WARNINGS=1 npx @11ty/eleventy",
		"build-ghpages": "cross-env NODE_NO_WARNINGS=1 npx @11ty/eleventy --pathprefix=/eleventy-base-blog/",
		"start": "cross-env NODE_NO_WARNINGS=1 npx @11ty/eleventy --serve --quiet",
		"start-ghpages": "cross-env NODE_NO_WARNINGS=1 npx @11ty/eleventy --pathprefix=/eleventy-base-blog/ --serve --quiet",
		"debug": "cross-env DEBUG=Eleventy* NODE_NO_WARNINGS=1 npx @11ty/eleventy",
		"debugstart": "cross-env DEBUG=Eleventy* NODE_NO_WARNINGS=1 npx @11ty/eleventy --serve --quiet",
		"benchmark": "cross-env DEBUG=Eleventy:Benchmark* NODE_NO_WARNINGS=1 npx @11ty/eleventy"
	},
	"author": {
		"name": "Domz",
		"email": "contact@domzlab.com",
		"url": "https://domzlab.com/"
	},
	"license": "MIT",
	"engines": {
		"node": ">=24"
	},
	"funding": {
		"type": "opencollective",
		"url": "https://opencollective.com/11ty"
	},
	"bugs": {
		"url": "https://github.com/11ty/eleventy-base-blog/issues"
	},
	"homepage": "https://github.com/11ty/eleventy-base-blog#readme",
	"devDependencies": {
		"@11ty/eleventy": "^3.1.5",
		"@11ty/eleventy-img": "^6.0.4",
		"@11ty/eleventy-navigation": "^1.0.5",
		"@11ty/eleventy-plugin-rss": "^3.0.0",
		"@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
		"cross-env": "^10.1.0",
		"luxon": "^3.7.2",
		"prismjs": "^1.30.0",
		"zod": "^4.3.6",
		"zod-validation-error": "^5.0.0"
	},
	"dependencies": {
		"@zachleat/heading-anchors": "^1.0.5"
	}
}
